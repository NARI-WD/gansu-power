  "sourceCards": [
    {
      "title": "燃料价格",
      "source": "公开能源统计、企业年报、区域调研与行业均价共同校核。",
      "method": "2024 采用调研水平，2025 起反映煤价回落后保持稳定；天然气作为区域基准参数延续。",
      "tone": "fuel"
    },
    {
      "title": "碳约束参数",
      "source": "全国碳市场发电行业配额方案与生态环境部公开市场信息。",
      "method": "配额强度由起始值向 2050 年零配额收敛，碳价按中长期上行轨迹外推至 2060 年。",
      "tone": "carbon"
    },
    {
      "title": "甘肃容量造价",
      "source": "省内代表性项目投资、装机规模披露与可再生能源工程造价资料。",
      "method": "常规电源维持稳定，水电平滑递增，风电、光伏、光热按目标降本路径逐年下降。",
      "tone": "gansu"
    },
    {
      "title": "区域造价对比",
      "source": "西北其他省区核准批复、环评公示、招投标公告及全国性造价指标。",
      "method": "以区域相对差异为核心，不追求单个项目精确造价，统一使用平滑插值刻画长期趋势。",
      "tone": "regional"
    }
  ],
