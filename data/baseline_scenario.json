{
  "metadata": {
    "sourceDocument": "2026.05.10-院士4期基准情景说明.docx",
    "sourceExcel": "2026.05.08-院士4期基础路径-最新版.xlsx",
    "yearRange": [
      2024,
      2060
    ],
    "notes": "现有经济参数沿用当前 UI 数据；本数据仅补充基准情景口径、流程图与基础路径曲线。"
  },
  "overview": {
    "title": "基准情景说明与关键参数",
    "lead": "以甘肃省为重点研究对象，结合全国与西北边界条件，展示 2024–2060 年电源转型路径、电量平衡、CCUS 布局与关键参数。",
    "kpis": [
      {
        "label": "研究周期",
        "value": "2024–2060",
        "note": "规划尺度转型时间步长为年"
      },
      {
        "label": "研究重点",
        "value": "甘肃省域",
        "note": "全国与西北作为研究边界"
      },
      {
        "label": "核心路径",
        "value": "总量 / 新能源 / CCUS",
        "note": "承接路径推演逻辑"
      },
      {
        "label": "电源范围",
        "value": "8 类资源",
        "note": "含煤电、水电、风光光热、其他与储能"
      }
    ]
  },
  "boundaries": [
    {
      "title": "空间边界",
      "items": [
        "全国及西北地区作为研究边界",
        "研究重点为甘肃省域范围"
      ]
    },
    {
      "title": "时间边界",
      "items": [
        "仿真起始年为 2024 年",
        "仿真推演年为 2025–2060 年",
        "2025 年实际数据用于校验"
      ]
    },
    {
      "title": "领域边界",
      "items": [
        "电源、电网、用电与储能统筹考虑",
        "外送通道采用宏观容量与数量约束"
      ]
    },
    {
      "title": "模型颗粒度",
      "items": [
        "煤电细化至机组级",
        "水电、风电、光伏、光热按投运年份聚类"
      ]
    }
  ],
  "dataSources": [
    {
      "period": "1995–2023",
      "source": "能源数据简明手册、国家能源局、国家统计局等"
    },
    {
      "period": "2024–2025",
      "source": "甘肃发改委、甘肃省政府办公厅、商务厅、工信厅等"
    },
    {
      "period": "2026–2035",
      "source": "甘肃经研院边界条件文件与收资表"
    },
    {
      "period": "2035–2060",
      "source": "基准情景路径设计与模型推演"
    }
  ],
  "pathwayFigure": {
    "title": "转型路径仿真推演思路",
    "src": "data/scenario_figures/figure-1-pathway.png",
    "caption": "按照全国碳中和目标、电力减排任务与区域解耦逻辑，形成甘肃省基准转型路径。"
  },
  "pathwaySteps": [
    {
      "title": "框定全国碳排碳汇边界",
      "text": "先以权威统计、能源资料和碳中和目标确定全国全社会碳排放与碳汇边界，明确电力系统需要承担的减排空间和长期约束。"
    },
    {
      "title": "分解电力碳减排任务",
      "text": "再扣除非二氧化碳温室气体、非电领域排放与碳汇，提取电力部门减排和增汇任务，并转化为电源结构、发电量和 CCUS 的路径约束。"
    },
    {
      "title": "解耦至西北与甘肃",
      "text": "最后按整体保熵还原思路，将全国任务分解为西北和甘肃的发电总量、新能源发电量与煤电 CCUS 路径，用于后续仿真推演。"
    }
  ],
